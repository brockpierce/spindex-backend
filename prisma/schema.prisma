// This is your Prisma schema file. It defines every table in the app as a
// "model" below. Run `npx prisma migrate dev --name init` after editing
// this file to create/update the actual SQLite database to match it.
//
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  username     String   @unique
  displayName  String
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())

  reviews      Review[]
  listenStatus ListenStatus[]
  lists        List[]
  favorites    Favorite[]
  savedLists   SavedList[]

  following Follow[] @relation("Following")
  followers Follow[] @relation("Followers")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followedId  String
  locked      Boolean  @default(false) // true = cannot be unfollowed (founder account)
  createdAt   DateTime @default(now())

  follower User @relation("Following", fields: [followerId], references: [id])
  followed User @relation("Followers", fields: [followedId], references: [id])

  @@unique([followerId, followedId])
}

// One row per album, whether it came from MusicBrainz (musicbrainzId set)
// or was added manually by a user (musicbrainzId null). This is the table
// the MusicBrainz import script populates in bulk.
model Album {
  id            String   @id @default(cuid())
  title         String
  artistName    String
  releaseYear   Int?
  releaseType   String?  @default("Album") // "Album" | "EP" | "Single" | "Broadcast" | "Other"
  coverArtUrl   String?
  musicbrainzId String?  @unique
  mbRatingCount Int?     @default(0)
  createdByUserId String?
  createdAt     DateTime @default(now())

  reviews      Review[]
  listenStatus ListenStatus[]
  listItems    ListItem[]
  favorites    Favorite[]

  @@index([title])
  @@index([artistName])
  @@index([mbRatingCount])
}

// Romanized / locale-specific aliases for artists, sourced from
// MusicBrainz. Joined to Album by artistName string (the DB has no
// artist model), so "カヒミ・カリィ" on Album matches an alias row
// with alias="Kahimi Karie". Search uses these to translate Latin-script
// queries into results for artists whose primary name is in another script.
model ArtistAlias {
  id                   String   @id @default(cuid())
  // Native-script artist name matching Album.artistName -- the join key.
  artistName           String
  // A romanized or locale-specific spelling, e.g. "Kahimi Karie" or "BTS".
  alias                String
  // BCP-47 locale from MusicBrainz (en, ja, ko, etc.), null if unknown.
  locale               String?
  // MusicBrainz artist MBID -- used to dedup across re-runs and to
  // identify which artist an alias belongs to.
  musicbrainzArtistId  String
  createdAt            DateTime @default(now())

  @@unique([musicbrainzArtistId, alias])
  @@index([artistName])
  @@index([alias])
}

model Review {
  id              String   @id @default(cuid())
  userId          String
  albumId         String
  rating          Int // 1-10 scale
  reviewText      String?
  favTrack        String?
  leastFavTrack   String?
  listenedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  album Album @relation(fields: [albumId], references: [id])

  @@unique([userId, albumId])
}

model ListenStatus {
  id        String   @id @default(cuid())
  userId    String
  albumId   String
  status    String // "want_to_listen" | "listened"
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  album Album @relation(fields: [albumId], references: [id])

  @@unique([userId, albumId])
}

model List {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  items     ListItem[]
  savedBy   SavedList[]
}

model ListItem {
  id       String  @id @default(cuid())
  listId   String
  albumId  String
  position Int
  note     String?

  list  List  @relation(fields: [listId], references: [id])
  album Album @relation(fields: [albumId], references: [id])

  @@unique([listId, albumId])
}

// A user bookmarking someone else's public list -- this is what powers
// the "saved lists" section, separate from "your lists" (which is the
// List model above, owned directly by userId).
model SavedList {
  id        String   @id @default(cuid())
  userId    String
  listId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  list List @relation(fields: [listId], references: [id])

  @@unique([userId, listId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  albumId   String
  position  Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  album Album @relation(fields: [albumId], references: [id])

  @@unique([userId, albumId])
}

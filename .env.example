# Copy this file to .env and adjust if needed.
# SQLite stores the whole database in a single file, so the URL is just a
# path on disk -- no separate database server to run.
DATABASE_URL="file:./dev.db"

# Used to sign session cookies. For real use, replace this with a random
# string -- in a terminal, `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# generates one for you. The placeholder below is fine for local dev only.
SESSION_SECRET="dev-only-secret-change-this-in-production"

# Where your frontend runs locally -- needed so the server allows it to
# make requests with cookies attached. Vite's default dev port is 5173.
FRONTEND_URL="http://localhost:5173"

PORT=3001

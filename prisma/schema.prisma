generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  username     String   @unique
  displayName  String
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())

  reviews              Review[]
  listenStatus         ListenStatus[]
  lists                List[]
  favorites            Favorite[]
  savedLists           SavedList[]
  reviewReactions      ReviewReaction[]
  reviewComments       ReviewComment[]
  albumMixes           AlbumMix[]
  textPosts            TextPost[]
  notificationsReceived Notification[] @relation("NotifRecipient")
  notificationsSent     Notification[] @relation("NotifActor")

  following Follow[] @relation("Following")
  followers Follow[] @relation("Followers")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followedId  String
  locked      Boolean  @default(false)
  createdAt   DateTime @default(now())

  follower User @relation("Following", fields: [followerId], references: [id])
  followed User @relation("Followers", fields: [followedId], references: [id])

  @@unique([followerId, followedId])
}

model Album {
  id              String   @id @default(cuid())
  title           String
  artistName      String
  releaseYear     Int?
  releaseType     String?  @default("Album")
  coverArtUrl     String?
  musicbrainzId   String?  @unique
  mbRatingCount   Int?     @default(0)
  createdByUserId String?
  createdAt       DateTime @default(now())

  reviews      Review[]
  listenStatus ListenStatus[]
  listItems    ListItem[]
  favorites    Favorite[]
  albumTags    AlbumTag[]
  mixItems     AlbumMixItem[]

  @@index([title])
  @@index([artistName])
  @@index([mbRatingCount])
}

model ArtistAlias {
  id                   String   @id @default(cuid())
  artistName           String
  alias                String
  locale               String?
  musicbrainzArtistId  String
  createdAt            DateTime @default(now())

  @@unique([musicbrainzArtistId, alias])
  @@index([artistName])
  @@index([alias])
}

model AlbumTag {
  id              String   @id @default(cuid())
  albumId         String
  tag             String
  createdByUserId String
  createdAt       DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([albumId, tag])
  @@index([tag])
}

model Review {
  id              String   @id @default(cuid())
  userId          String
  albumId         String
  rating          Int
  reviewText      String?
  favTrack        String?
  leastFavTrack   String?
  listenedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id])
  album     Album            @relation(fields: [albumId], references: [id])
  comments  ReviewComment[]

  @@unique([userId, albumId])
}

model ReviewReaction {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  kind      String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])

  @@unique([reviewId, userId])
}

model ReviewComment {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  text      String
  parentId  String?
  createdAt DateTime @default(now())

  review  Review          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id])
  parent  ReviewComment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies ReviewComment[] @relation("CommentThread")
}

model AlbumMix {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id])
  items AlbumMixItem[]
}

model AlbumMixItem {
  id       String  @id @default(cuid())
  mixId    String
  albumId  String
  position Int
  note     String?

  mix   AlbumMix @relation(fields: [mixId], references: [id], onDelete: Cascade)
  album Album    @relation(fields: [albumId], references: [id])

  @@unique([mixId, albumId])
}

// Simple text posts — status updates, thoughts, etc. that don't
// need an album attached. Shows up in the feed alongside reviews.
model TextPost {
  id        String   @id @default(cuid())
  userId    String
  text      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

// Notification types: "follow", "comment", "reply", "reaction"
// referenceId points to the relevant object (review ID for comment/reaction,
// user ID for follow).
model Notification {
  id           String   @id @default(cuid())
  recipientId  String
  actorId      String
  type         String   // "follow" | "comment" | "reply" | "reaction"
  referenceId  String?  // reviewId for comment/reaction, null for follow
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())

  recipient User @relation("NotifRecipient", fields: [recipientId], references: [id])
  actor     User @relation("NotifActor", fields: [actorId], references: [id])

  @@index([recipientId, read])
  @@index([recipientId, createdAt])
}

model ListenStatus {
  id        String   @id @default(cuid())
  userId    String
  albumId   String
  status    String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  album Album @relation(fields: [albumId], references: [id])

  @@unique([userId, albumId])
}

model List {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id])
  items   ListItem[]
  savedBy SavedList[]
}

model ListItem {
  id       String  @id @default(cuid())
  listId   String
  albumId  String
  position Int
  note     String?

  list  List  @relation(fields: [listId], references: [id])
  album Album @relation(fields: [albumId], references: [id])

  @@unique([listId, albumId])
}

model SavedList {
  id        String   @id @default(cuid())
  userId    String
  listId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  list List @relation(fields: [listId], references: [id])

  @@unique([userId, listId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  albumId   String
  position  Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  album Album @relation(fields: [albumId], references: [id])

  @@unique([userId, albumId])
}
